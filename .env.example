# Copy to .env and override any values as needed.
# Process environment always wins over .env.

# ── tsetmc cdn ───────────────────────────────────────────────────────────────
# Base URL of the TSETMC CDN. BEST_LIMITS_URL is derived as
#   {TSETMC_CDN_BASE_URL}/api/BestLimits/{ticker}/{deven}
TSETMC_CDN_BASE_URL=http://cdn.tsetmc.com

# ── broker signalr hubs ──────────────────────────────────────────────────────
# WebSocket hub URLs (no trailing slash). The script appends ?access_token=…
PARSIAN_SIGNALR_URL=wss://signal.parsianbroker.com/SignalHub
PASARGAD_SIGNALR_URL=wss://pasargad-signal.tsetab.ir/SignalHub

# Pasargad REST API base — host of the SubscribeInstrument / MarketWatches
# endpoints. Same host as the WS hub in practice but kept separate so it
# can move independently and isn't reverse-engineered from the WS URL.
PASARGAD_API_BASE_URL=https://pasargad-signal.tsetab.ir

# ── pasargad auth ────────────────────────────────────────────────────────────
# Long-lived bearer token + cookie copied from a logged-in session.
# Token is sent both as the ?access_token=… ws query param and as the
# Authorization header on REST subscribe calls. Cookie is REST-only.
PASARGAD_AUTH_TOKEN=
PASARGAD_COOKIE=

# ── nibi ─────────────────────────────────────────────────────────────────────
# Nibi broker — assumed wire-compatible with Pasargad (SignalR + REST
# SubscribeInstrument). Token is sent both as ?access_token=… on the ws
# query and as the Authorization header on REST subscribe calls. Cookie
# is REST-only.
NIBI_SIGNALR_URL=
NIBI_API_BASE_URL=
NIBI_AUTH_TOKEN=
NIBI_COOKIE=

# ── data dir ─────────────────────────────────────────────────────────────────
# Local directory for runtime artefacts (e.g. {uuid}.log files emitted by
# the broker stream). Relative paths resolve against the repo root.
DATA_DIR=data

# ── historical storage ───────────────────────────────────────────────────────
# Per-day Parquet files written / read by `storage.StorageClient`, named
# `{ticker}_{jalali_date}.parquet`. Relative paths resolve against the repo
# root, same as DATA_DIR.
ORDERBOOKS_DIR=data/orderbooks
TRADES_DIR=data/trades

# ── redis ────────────────────────────────────────────────────────────────────
# Local Redis instance for live broker streams. Each `PasargadStreamer` /
# `MockPasargadStreamer` does `XADD {isin}:orderbook ...` against it.
# Spin one up with `docker compose up -d redis`.
REDIS_URI=localhost
REDIS_PORT=6379

# ── instrument registry ──────────────────────────────────────────────────────
# YAML file mapping each instrument to its (isin, ins_code, symbol, name) —
# the canonical bridge between TSETMC's numeric InsCode and the brokers'
# 12-char ISIN. Loaded by `instruments.InstrumentRegistry`. Relative paths
# resolve against the repo root.
INSTRUMENTS_FILE=data/instruments.yaml

# ── mock-streamer trading window ─────────────────────────────────────────────
# TSETMC's CDN ships parquets that include head/tail noise outside the real
# trading session (rows from ~06:00:00, plus post-close padding). The mock
# streamer drops snapshots whose `time` is outside `[MARKET_OPEN, MARKET_END]`
# before replay so consumers see only the live-session shape. Inclusive on
# both ends; zero-padded `HH:MM:SS`.
MARKET_OPEN=12:00:00
MARKET_END=18:00:00
